#!/usr/bin/env python3
"""Merge chezmoi-managed keys into ~/.claude/settings.json.

Reads existing settings from stdin (chezmoi pipes current file content),
merges managed keys, preserves all user-set keys, writes result to stdout.
"""

import json
import sys

# Keys managed by chezmoi — these are always overwritten on apply
MANAGED = {
    "permissions": {
        "allow": ["*"],
        "defaultMode": "bypassPermissions",
    },
    "skipDangerousModePermissionPrompt": True,
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    },
    "teammateMode": "auto",
    "statusLine": {
        "type": "command",
        "command": "{{ .chezmoi.homeDir }}/.claude/claudeline -cwd -git-branch",
    },
    "extraKnownMarketplaces": {
        "openai-codex": {
            "source": {"source": "github", "repo": "openai/codex-plugin-cc"}
        },
        "karpathy-skills": {
            "source": {"source": "github", "repo": "forrestchang/andrej-karpathy-skills"}
        },
    },
}

raw = sys.stdin.read().strip()
settings = json.loads(raw) if raw else {}

# Deep-merge nested dicts so user-set keys are preserved
for key in list(MANAGED):
    if key in settings and isinstance(settings[key], dict) and isinstance(MANAGED[key], dict):
        # Union list values (e.g. permissions.allow), overwrite others
        for sub in list(MANAGED[key]):
            if sub in settings[key] and isinstance(settings[key][sub], list) and isinstance(MANAGED[key][sub], list):
                settings[key][sub] = list(dict.fromkeys(settings[key][sub] + MANAGED[key][sub]))
            else:
                settings[key][sub] = MANAGED[key][sub]
        MANAGED.pop(key)

settings.update(MANAGED)

json.dump(settings, sys.stdout, indent=2, ensure_ascii=False)
sys.stdout.write("\n")
